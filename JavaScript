                          width: 36, height: 36, borderRadius: "50%", flexShrink: 0,
                          background: i === 0 ? COLORS.accentGlow : COLORS.surfaceAlt,
                          border: `2px solid ${i === 0 ? COLORS.accent : COLORS.border}`,
                          display: "flex", alignItems: "center", justifyContent: "center",
                          fontFamily: "monospace", fontSize: 13, fontWeight: 700, color: i === 0 ? COLORS.accent : COLORS.textMid
                        }}>{c.cycle}</div>
                        <div style={{ flex: 1 }}>
                          <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 4 }}>
                            <span style={{ fontFamily: "monospace", fontSize: 13, color: COLORS.text }}>
                              {c.month === 0 ? "Day 0 — Initial Setup" : `Month ${c.month} — Redraw`}
                            </span>
                            <span style={{ fontFamily: "monospace", fontSize: 13, color: COLORS.accent, fontWeight: 700 }}>{fmt(c.draw)}</span>
                          </div>
                          <div style={{ fontSize: 12, color: COLORS.textMid }}>
                            {c.month === 0
                              ? `Drew full ${fmt(c.draw)} HELOC → mortgage ${fmt(c.mortgageAfter)}. Applied ${fmt(result.savingsApplied)} savings → HELOC starts at ${fmt(c.draw - result.savingsApplied)}.`
                              : `Drew ${Math.round(redrawPct * 100)}% of available equity → mortgage drops to ${fmt(c.mortgageAfter)}.`}
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                )}

                {/* Tab: Comparison */}
                {activeTab === "comparison" && (
                  <div style={{ background: COLORS.surface, border: `1px solid ${COLORS.border}`, borderRadius: 10, overflow: "hidden" }}>
                    <div style={{ padding: "14px 18px", borderBottom: `1px solid ${COLORS.border}`, fontSize: 12, color: COLORS.textMid, fontFamily: "monospace" }}>
                      Three strategies compared side by side
                    </div>
                    {[
                      {
                        label: "30yr — Do Nothing Extra",
                        payoff: mo(result.baseline.months),
                        interest: result.baseline.totalInt,
                        heloc: 0,
                        total: result.baseline.totalInt,
                        liquidity: "Full (no extra payments)",
                        color: COLORS.textDim,
                        note: "All your money stays liquid but you pay maximum interest"
                      },
                      {
                        label: `Velocity Banking (${Math.round(redrawPct * 100)}% redraw)`,
                        payoff: mo(result.months),
                        interest: result.totalMInt,
                        heloc: result.totalHInt,
                        total: result.total,
                        liquidity: fmt(homeValue * 0.8) + " accessible at payoff",
                        color: COLORS.accent,
                        note: "Best balance of payoff speed, interest savings, and liquidity",
                        highlight: true
                      },
                      {
                        label: "Direct Extra Principal",
                        payoff: mo(result.direct.months),
                        interest: result.direct.totalInt,
                        heloc: 0,
                        total: result.direct.totalInt,
                        liquidity: "$0 — all surplus locked in mortgage",
                        color: COLORS.amber,
                        note: "Cheapest total interest but requires locking away all surplus cash"
                      },
                    ].map((s, i) => (
                      <div key={i} style={{
                        padding: "18px 20px",
                        borderBottom: i < 2 ? `1px solid ${COLORS.border}` : "none",
                        background: s.highlight ? COLORS.accentGlow : "transparent",
                        borderLeft: s.highlight ? `3px solid ${COLORS.accent}` : "3px solid transparent"
                      }}>
                        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 10 }}>
                          <span style={{ fontFamily: "monospace", fontSize: 14, fontWeight: 700, color: s.color }}>{s.label}</span>
                          <span style={{ fontFamily: "monospace", fontSize: 13, color: COLORS.textMid }}>Payoff: <span style={{ color: COLORS.text }}>{s.payoff}</span></span>
                        </div>
                        <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: 10, marginBottom: 8 }}>
                          <div>
                            <div style={{ fontSize: 10, color: COLORS.textDim, fontFamily: "monospace", textTransform: "uppercase", marginBottom: 3 }}>Mortgage Int</div>
                            <div style={{ fontSize: 15, fontFamily: "monospace", color: COLORS.amber }}>{fmt(s.interest)}</div>
                          </div>
                          <div>
                            <div style={{ fontSize: 10, color: COLORS.textDim, fontFamily: "monospace", textTransform: "uppercase", marginBottom: 3 }}>HELOC Int</div>
                            <div style={{ fontSize: 15, fontFamily: "monospace", color: s.heloc > 0 ? COLORS.accent : COLORS.textDim }}>{fmt(s.heloc)}</div>
                          </div>
                          <div>
                            <div style={{ fontSize: 10, color: COLORS.textDim, fontFamily: "monospace", textTransform: "uppercase", marginBottom: 3 }}>Total Interest</div>
                            <div style={{ fontSize: 15, fontFamily: "monospace", fontWeight: 700, color: s.color }}>{fmt(s.total)}</div>
                          </div>
                        </div>
                        <div style={{ fontSize: 11, color: COLORS.textDim }}>
                          <span style={{ color: COLORS.textMid }}>Liquidity: </span>{s.liquidity}
                        </div>
                        <div style={{ fontSize: 11, color: COLORS.textDim, marginTop: 4, fontStyle: "italic" }}>{s.note}</div>
                      </div>
                    ))}
                  </div>
                )}
              </>
            )}

            {!result && (
              <div style={{ background: COLORS.surface, border: `1px solid ${COLORS.redDim}`, borderRadius: 10, padding: 28, textAlign: "center" }}>
                <div style={{ fontSize: 32, marginBottom: 12 }}>⚠</div>
                <div style={{ color: COLORS.red, fontFamily: "monospace", fontSize: 14, marginBottom: 8 }}>INSUFFICIENT EQUITY</div>
                <div style={{ color: COLORS.textMid, fontSize: 13 }}>
                  Your mortgage balance ({fmt(mortgageBal)}) exceeds 80% LTV ({fmt(homeValue * 0.8)}).<br />
                  You need at least {fmt(mortgageBal - homeValue * 0.8)} more equity to open a HELOC.
                </div>
              </div>
            )}
          </div>
        </div>
      </div>

      <div style={{ maxWidth: 1100, margin: "0 auto", padding: "0 32px", borderTop: `1px solid ${COLORS.border}`, paddingTop: 20 }}>
        <p style={{ fontSize: 11, color: COLORS.textDim, fontFamily: "monospace", textAlign: "center" }}>
          This calculator is for educational purposes only. Assumes 80% LTV HELOC, income deposited on 1st & 15th, CC paid day 25, prime-based HELOC rate.
          Consult a financial advisor before making mortgage decisions.
        </p>
      </div>
    </div>
  );
}
