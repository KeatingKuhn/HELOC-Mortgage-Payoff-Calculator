const COLORS = {
  bg: "#0a0e1a",
  surface: "#111827",
  surfaceAlt: "#1a2235",
  border: "#1e2d45",
  accent: "#00d4ff",
  accentDim: "#0099bb",
  accentGlow: "rgba(0,212,255,0.15)",
  green: "#00e5a0",
  greenDim: "rgba(0,229,160,0.12)",
  red: "#ff4d6d",
  redDim: "rgba(255,77,109,0.12)",
  amber: "#ffb700",
  amberDim: "rgba(255,183,0,0.12)",
  text: "#e8f0fe",
  textMid: "#8899bb",
  textDim: "#4a5568",
};

function simulate(params) {
  const {
    mortgageBal, mortgageRate, mortgagePmt,
    homeValue, helocRate, monthlyIncome,
    livingExpenses, monthlyDebts, savings,
    redrawPct
  } = params;

  const ltvLimit = 0.80;
  const dailyRate = helocRate / 100 / 365;
  const mr = mortgageRate / 100 / 12;

  const maxDraw = Math.max(0, (homeValue * ltvLimit) - mortgageBal);
  if (maxDraw < 5000) return null;

  const initialDraw = maxDraw;
  const savingsApplied = Math.min(savings, initialDraw);
  let mBal = mortgageBal - initialDraw;
  let hBal = initialDraw - savingsApplied;

  let totalMInt = 0, totalHInt = 0;
  let month = 0;
  const yearData = [];
  const cycleLog = [{ cycle: 1, month: 0, draw: initialDraw, mortgageAfter: mBal }];
  let yrMInt = 0, yrHInt = 0, cycleCount = 1;

  function oneMonth(hb, mp, dp) {
    let bal = hb + mp + dp;
    let cashBuf = 0, interest = 0;
    const half = monthlyIncome / 2;
    for (let day = 1; day <= 30; day++) {
      if (day === 1 || day === 15) {
        const pay = Math.min(bal, half);
        bal -= pay; cashBuf += (half - pay);
      }
      if (day === 25) {
        const fc = Math.min(cashBuf, livingExpenses);
        cashBuf -= fc; bal += (livingExpenses - fc);
        bal = Math.max(0, bal);
      }
      interest += Math.max(0, bal) * dailyRate;
    }
    bal = Math.max(0, bal - cashBuf);
    return { endBal: bal, interest };
  }

  while ((mBal > 0.01 || hBal > 0.01) && month < 600) {
    month++;
    const mp = mBal > 0 ? mortgagePmt : 0;
    const dp = monthlyDebts;
    const r = oneMonth(hBal, mp, dp);
    totalHInt += r.interest; yrHInt += r.interest;
    hBal = r.endBal;
    if (mBal > 0) {
      const mInt = mBal * mr;
      totalMInt += mInt; yrMInt += mInt;
      mBal = Math.max(0, mBal + mInt - mp);
    }
    if (hBal < 500 && mBal > 1000) {
      const ceiling = (homeValue * ltvLimit) - mBal;
      const draw = Math.min(ceiling * redrawPct, mBal);
      if (draw > 1000) {
        mBal -= draw; hBal = draw; cycleCount++;
        cycleLog.push({ cycle: cycleCount, month, draw, mortgageAfter: mBal });
      }
    }
    if (month % 12 === 0) {
      yearData.push({
        year: month / 12, mBal, hBal, yrMInt, yrHInt,
        yrTotal: yrMInt + yrHInt,
        cumTotal: totalMInt + totalHInt,
        liquidity: Math.max(0, (homeValue * ltvLimit) - mBal - hBal)
      });
      yrMInt = 0; yrHInt = 0;
    }
  }
  if (month % 12 !== 0) {
    yearData.push({
      year: Math.ceil(month / 12), mBal: 0, hBal: 0,
      yrMInt, yrHInt, yrTotal: yrMInt + yrHInt,
      cumTotal: totalMInt + totalHInt,
      liquidity: homeValue * ltvLimit,
      partial: true
    });
  }

  // Baseline no extra
  let bMBal = mortgageBal, bMo = 0, bMInt = 0;
  while (bMBal > 0.01 && bMo < 600) {
    bMo++; const i = bMBal * mr; bMInt += i;
    bMBal = Math.max(0, bMBal + i - mortgagePmt);
  }

  // Direct extra principal
  let dMBal = mortgageBal - savings, dMo = 0, dMInt = 0;
  const extra = Math.max(0, monthlyIncome - livingExpenses - mortgagePmt - monthlyDebts);
  while (dMBal > 0.01 && dMo < 600) {
    dMo++; const i = dMBal * mr; dMInt += i;
    dMBal = Math.max(0, dMBal + i - Math.min(dMBal + i, mortgagePmt + extra));
  }

  return {
    months: month, totalMInt, totalHInt,
    total: totalMInt + totalHInt,
    yearData, cycleLog, cycleCount,
    initialDraw, maxDraw, savingsApplied,
    baseline: { months: bMo, totalInt: bMInt },
    direct: { months: dMo, totalInt: dMInt },
    interestSavedVsBaseline: bMInt - (totalMInt + totalHInt),
    extraCostVsDirect: (totalMInt + totalHInt) - dMInt,
  };
}

const fmt = (n) => "$" + Math.round(n).toLocaleString();
const fmtD = (n) => "$" + Number(n).toFixed(0);
const mo = (m) => `${Math.floor(m / 12)}y ${m % 12}mo`;

function SliderInput({ label, value, min, max, step, onChange, format, hint }) {
  return (
    <div style={{ marginBottom: 20 }}>
      <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 6 }}>
        <span style={{ fontSize: 12, color: COLORS.textMid, textTransform: "uppercase", letterSpacing: "0.08em", fontFamily: "monospace" }}>{label}</span>
        <span style={{ fontSize: 14, color: COLORS.accent, fontFamily: "monospace", fontWeight: 700 }}>{format(value)}</span>
      </div>
      <input
        type="range" min={min} max={max} step={step} value={value}
        onChange={e => onChange(Number(e.target.value))}
        style={{ width: "100%", accentColor: COLORS.accent, cursor: "pointer", height: 4 }}
      />
      {hint && <div style={{ fontSize: 11, color: COLORS.textDim, marginTop: 4 }}>{hint}</div>}
    </div>
  );
}

function NumberInput({ label, value, onChange, prefix = "$", suffix = "" }) {
  const [raw, setRaw] = useState(String(value));
  useEffect(() => { setRaw(String(value)); }, [value]);
  return (
    <div style={{ marginBottom: 16 }}>
      <div style={{ fontSize: 11, color: COLORS.textMid, textTransform: "uppercase", letterSpacing: "0.08em", fontFamily: "monospace", marginBottom: 5 }}>{label}</div>
      <div style={{ display: "flex", alignItems: "center", background: COLORS.bg, border: `1px solid ${COLORS.border}`, borderRadius: 6, overflow: "hidden" }}>
        {prefix && <span style={{ padding: "8px 10px", color: COLORS.textDim, fontFamily: "monospace", fontSize: 13, borderRight: `1px solid ${COLORS.border}` }}>{prefix}</span>}
        <input
          type="number" value={raw}
          onChange={e => { setRaw(e.target.value); const n = Number(e.target.value); if (!isNaN(n) && n >= 0) onChange(n); }}
          style={{ flex: 1, background: "transparent", border: "none", outline: "none", padding: "8px 10px", color: COLORS.text, fontFamily: "monospace", fontSize: 14 }}
        />
        {suffix && <span style={{ padding: "8px 10px", color: COLORS.textDim, fontFamily: "monospace", fontSize: 13, borderLeft: `1px solid ${COLORS.border}` }}>{suffix}</span>}
      </div>
    </div>
  );
}

function StatCard({ label, value, sub, color = COLORS.accent, glow }) {
  return (
    <div style={{
      background: COLORS.surfaceAlt, border: `1px solid ${COLORS.border}`,
      borderRadius: 10, padding: "16px 18px",
      boxShadow: glow ? `0 0 20px ${color}22` : "none",
      borderTop: `2px solid ${color}`
    }}>
      <div style={{ fontSize: 11, color: COLORS.textMid, textTransform: "uppercase", letterSpacing: "0.08em", fontFamily: "monospace", marginBottom: 6 }}>{label}</div>
      <div style={{ fontSize: 22, fontWeight: 800, color, fontFamily: "monospace" }}>{value}</div>
      {sub && <div style={{ fontSize: 11, color: COLORS.textDim, marginTop: 4 }}>{sub}</div>}
    </div>
  );
}

function YearRow({ y, isLast }) {
  const dominated = y.yrHInt > y.yrMInt;
  return (
    <tr style={{ borderBottom: `1px solid ${COLORS.border}` }}>
      <td style={{ padding: "10px 12px", fontFamily: "monospace", fontSize: 13, color: COLORS.textMid }}>
        {y.partial ? `Yr ${y.year}*` : `Year ${y.year}`}
      </td>
      <td style={{ padding: "10px 12px", fontFamily: "monospace", fontSize: 13, color: COLORS.text }}>{y.mBal > 0 ? fmt(y.mBal) : <span style={{ color: COLORS.green }}>✓ PAID</span>}</td>
      <td style={{ padding: "10px 12px", fontFamily: "monospace", fontSize: 13, color: COLORS.text }}>{fmt(y.hBal)}</td>
      <td style={{ padding: "10px 12px", fontFamily: "monospace", fontSize: 13, color: COLORS.amber }}>{fmtD(y.yrMInt)}</td>
      <td style={{ padding: "10px 12px", fontFamily: "monospace", fontSize: 13, color: dominated ? COLORS.red : COLORS.accent }}>{fmtD(y.yrHInt)}</td>
      <td style={{ padding: "10px 12px", fontFamily: "monospace", fontSize: 13, color: COLORS.textMid }}>{fmtD(y.yrTotal)}</td>
      <td style={{ padding: "10px 12px", fontFamily: "monospace", fontSize: 13, color: COLORS.green }}>{fmt(y.liquidity)}</td>
    </tr>
  );
}

